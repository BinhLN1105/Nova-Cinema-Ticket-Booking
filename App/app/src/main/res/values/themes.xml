<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ════════════════════════════════════════
         BASE APP THEME — Light (mặc định)
         Hỗ trợ toggle Dark/Light qua Settings
         ════════════════════════════════════════ -->
    <style name="Theme.CinemaApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/bottom_nav_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#1AE50914</item>
        <item name="colorControlActivated">@color/primary</item>

        <!-- Text Appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
    </style>

    <!-- Dark mode — statusBar icon màu sáng -->
    <style name="Theme.CinemaApp.Dark" parent="Theme.CinemaApp">
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen -->
    <style name="Theme.CinemaApp.Splash" parent="Theme.CinemaApp">
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- ════════════════════════════════
         SHAPES
         ════════════════════════════════ -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ════════════════════════════════
         TEXT APPEARANCES
         ════════════════════════════════ -->
    <style name="TextAppearance.Cinema.H1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Cinema.H2" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Cinema.H3" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Cinema.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.Cinema.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ════════════════════════════════
         BUTTON STYLES
         ════════════════════════════════ -->
    <!-- Primary button — đỏ nổi bật -->
    <style name="Widget.Cinema.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Secondary button — outlined -->
    <style name="Widget.Cinema.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Text button -->
    <style name="Widget.Cinema.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ════════════════════════════════
         INPUT FIELD STYLE
         ════════════════════════════════ -->
    <style name="Widget.Cinema.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_selector</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <!-- ════════════════════════════════
         CARD STYLE
         ════════════════════════════════ -->
    <style name="Widget.Cinema.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ════════════════════════════════
         BOTTOM NAVIGATION
         ════════════════════════════════ -->
    <style name="Widget.Cinema.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/bottom_nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_item_selector</item>
        <item name="itemTextColor">@color/bottom_nav_item_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>

</resources>