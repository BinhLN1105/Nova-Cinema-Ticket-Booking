<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_dark">

    <ImageView
        android:id="@+id/ivStatus"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_check"
        android:contentDescription="Status" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Đang xác nhận hủy vé..."
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Vui lòng đợi trong giây lát..."
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:textAlignment="center"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/accent_gold" />

    <Button
        android:id="@+id/btnBackToDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Quay lại chi tiết vé"
        android:visibility="gone"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textColor="@color/accent_gold"/>

</LinearLayout>
