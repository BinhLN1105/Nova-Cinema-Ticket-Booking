<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">


    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout android:id="@+id/swipeRefresh"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        
        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp">

                <!-- Page Title & Tab Switcher -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vé của tôi"
                    android:textColor="@color/on_surface"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_bottom_nav_rounded"
                    android:backgroundTint="@color/surface_container_low"
                    android:padding="4dp"
                    android:layout_marginBottom="24dp">
                    
                    <TextView
                        android:id="@+id/tabUpcoming"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Sắp chiếu"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_bottom_nav_rounded"
                        android:backgroundTint="@color/surface_container_highest"/>
                        
                    <TextView
                        android:id="@+id/tabHistory"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Lịch sử"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_variant"/>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                
                    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvBookings"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"/>
                    
                    <!-- Empty State -->
                    <LinearLayout android:id="@+id/tvEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="40dp"
                        android:visibility="gone">
                        
                        <ImageView android:layout_width="120dp" android:layout_height="120dp"
                            android:src="@drawable/ic_ticket" android:tint="@color/primary"
                            android:alpha="0.3" android:layout_marginBottom="24dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bạn chưa có vé nào cả" android:textColor="@color/on_surface"
                            android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="240dp" android:layout_height="wrap_content"
                            android:text="Hàng ngàn bộ phim bom tấn đang chờ bạn khám phá."
                            android:textColor="@color/on_surface_variant" android:textSize="14sp"
                            android:textAlignment="center" android:layout_marginTop="8dp" android:layout_marginBottom="32dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBrowseMovies"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:text="XEM LỊCH CHIẾU NGAY"
                            android:textColor="@color/on_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingHorizontal="32dp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="28dp"/>
                    </LinearLayout>

                    <!-- Login prompt for unauthenticated users -->
                    <LinearLayout android:id="@+id/layoutLoginPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="40dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:src="@drawable/ic_ticket"
                            android:tint="@color/on_surface_variant"
                            android:alpha="0.4"
                            android:layout_marginBottom="24dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đăng nhập để xem vé"
                            android:textColor="@color/on_surface"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="240dp"
                            android:layout_height="wrap_content"
                            android:text="Bạn cần đăng nhập để xem và quản lý vé của mình"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="14sp"
                            android:textAlignment="center"
                            android:layout_marginBottom="32dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLoginPrompt"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:text="ĐĂNG NHẬP"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingHorizontal="32dp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="28dp"/>
                    </LinearLayout>

                    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_gravity="center"
                        android:layout_marginTop="40dp"
                        android:visibility="gone" android:indeterminateTint="@color/primary"/>
                </FrameLayout>
                
                <ProgressBar android:id="@+id/progressBarLoadMore" android:layout_width="32dp"
                        android:layout_height="32dp" android:layout_gravity="center"
                        android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                        android:visibility="gone" android:indeterminateTint="@color/primary"/>
                        
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
