<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="8dp" android:gravity="center_vertical">
    <ImageView android:id="@+id/ivCombo" android:layout_width="56dp" android:layout_height="56dp"
        android:scaleType="centerCrop"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
        <TextView android:id="@+id/tvComboName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/on_surface"
            android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvComboDesc" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/on_surface_variant"
            android:textSize="11sp" android:maxLines="1"/>
        <TextView android:id="@+id/tvComboPrice" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/accent_gold"
            android:textSize="13sp"/>
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/btnMinus" android:layout_width="32dp" android:layout_height="32dp"
            android:text="−" android:gravity="center" android:textSize="18sp"
            android:textColor="@color/on_surface" android:background="@color/surface_variant"/>
        <TextView android:id="@+id/tvQty" android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="0" android:gravity="center" android:textColor="@color/on_surface" android:textSize="14sp"/>
        <TextView android:id="@+id/btnPlus" android:layout_width="32dp" android:layout_height="32dp"
            android:text="+" android:gravity="center" android:textSize="18sp"
            android:textColor="@color/white" android:background="@color/primary"/>
    </LinearLayout>
</LinearLayout>
