<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Top AppBar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingTop="32dp" android:paddingBottom="16dp" android:paddingHorizontal="16dp" android:gravity="center_vertical"
        android:background="@color/surface_glass" android:elevation="8dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_back" android:background="?selectableItemBackgroundBorderless" android:tint="@color/on_surface"
            android:layout_marginEnd="16dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Bắp &amp; Nước" android:textColor="@color/on_surface"
            android:textSize="20sp" android:textStyle="bold"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="80dp"
        android:paddingBottom="140dp"
        android:clipToPadding="false"
        android:fillViewport="true">
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Loyalty Reward Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/surface_container_high"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_wallet"
                        android:background="@drawable/bg_circle_secondary_dim"
                        android:padding="12dp"
                        android:tint="@color/secondary"
                        android:layout_marginEnd="16dp"/>
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CineNoir Gold Member"
                            android:textColor="@color/secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dùng điểm CP để đổi"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ProgressBar
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="120dp"
                                android:layout_height="6dp"
                                android:progress="75"
                                android:progressDrawable="@drawable/bg_progress_horizontal_secondary"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="112 / 150 pts"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Đổi Quà"
                        android:textColor="@color/on_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/secondary"
                        app:cornerRadius="20dp"
                        app:elevation="4dp"/>
                        
                </LinearLayout>
                
                <!-- Overlay shadow for border-left equivalent -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/secondary"/>
            </androidx.cardview.widget.CardView>

            <!-- Concession List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCombos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_combo" />

            <!-- Individual Items (Bento Style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                <View android:layout_width="8dp" android:layout_height="24dp" android:background="@color/primary" android:layout_marginEnd="12dp" android:backgroundTint="@color/primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LẺ &amp; THÊM"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"/>
            </LinearLayout>

            <!-- Lẻ Thêm Grid - Static Placeholders per Design -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="32dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_border_outline"
                    android:backgroundTint="@color/surface_container_low">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_food" android:tint="@color/primary" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bắp Caramel" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="65,000đ" android:textColor="@color/on_surface_variant" android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_border_outline"
                    android:backgroundTint="@color/surface_container_low">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_drink" android:tint="@color/primary" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pepsi Black" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40,000đ" android:textColor="@color/on_surface_variant" android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_border_outline"
                    android:backgroundTint="@color/surface_container_low">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_food" android:tint="@color/primary" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nacho Cheese" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="82,000đ" android:textColor="@color/on_surface_variant" android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_border_outline"
                    android:backgroundTint="@color/surface_container_low">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_sweet" android:tint="@color/primary" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gelato Cup" android:textColor="@color/on_surface" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="55,000đ" android:textColor="@color/on_surface_variant" android:textSize="12sp"/>
                </LinearLayout>
            </GridLayout>
            
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Checkout Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#DD262626"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TỔNG CỘNG TẠM TÍNH"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:id="@+id/tvTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0đ"
                        android:textColor="@color/primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:id="@+id/tvItemSelected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(0 món)"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHIM ĐÃ CHỌN"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"/>
                <TextView
                    android:id="@+id/tvMovieTitle"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textAlignment="viewEnd"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="BỎ QUA"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/surface_container_highest"
                app:cornerRadius="28dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline_variant"
                android:layout_marginEnd="8dp"/>
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:text="TIẾP TỤC"
                android:textColor="@color/on_primary_fixed"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:backgroundTint="@color/primary"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="textEnd"
                app:iconTint="@color/on_primary_fixed"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center"
        android:visibility="gone" android:indeterminateTint="@color/primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
