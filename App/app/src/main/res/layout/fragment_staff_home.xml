<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A0E1A"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="NOVA STAFF"
            app:titleTextColor="#F5C518"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Title" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════ -->
            <!-- HEADER — Chào hỏi + Ngày                  -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xin chào, Nhân viên! 👋"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Hôm nay"
                    android:textSize="13sp"
                    android:textColor="#7A8BA0" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════ -->
            <!-- STATS SECTION LABEL                        -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="#F5C518"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="THỐNG KÊ NHANH"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textColor="#F5C518" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefresh"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    app:icon="@drawable/ic_refresh"
                    app:iconTint="#7A8BA0"
                    app:iconSize="18dp" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════ -->
            <!-- STATS CARDS — Thiết kế mới                -->
            <!-- ══════════════════════════════════════════ -->

            <!-- CARD 1: Suất chiếu hôm nay — Gold accent -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#111827"
                app:strokeWidth="1dp"
                app:strokeColor="#1E3A5F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- Left accent bar + icon -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="56dp"
                            android:background="#F5C518"
                            android:layout_marginEnd="16dp"
                            android:layout_gravity="center_vertical" />

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_stat_icon_circle"
                            android:backgroundTint="#1F2937">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_movie"
                                app:tint="#F5C518" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tvShowtimesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:textColor="#F5C518"
                            android:lineHeight="44sp"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Suất chiếu hôm nay"
                            android:textSize="12sp"
                            android:textColor="#6B7E94"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Loading -->
                    <ProgressBar
                        android:id="@+id/pbShowtimes"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:visibility="gone"
                        android:indeterminateTint="#F5C518" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 2: Vé đã soát hôm nay — Green accent -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#111827"
                app:strokeWidth="1dp"
                app:strokeColor="#1A3A2C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="56dp"
                            android:background="#22C55E"
                            android:layout_marginEnd="16dp"
                            android:layout_gravity="center_vertical" />

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_stat_icon_circle"
                            android:backgroundTint="#0F2318">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_qr_scanner"
                                app:tint="#22C55E" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tvCheckedTodayValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E"
                            android:lineHeight="44sp"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vé đã soát hôm nay"
                            android:textSize="12sp"
                            android:textColor="#6B7E94"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 3: Vé đã soát tháng này — Purple accent -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#111827"
                app:strokeWidth="1dp"
                app:strokeColor="#2A1A3A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="56dp"
                            android:background="#A855F7"
                            android:layout_marginEnd="16dp"
                            android:layout_gravity="center_vertical" />

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_stat_icon_circle"
                            android:backgroundTint="#1A0F2A">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_ticket"
                                app:tint="#A855F7" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tvCheckedMonthValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:textColor="#A855F7"
                            android:lineHeight="44sp"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vé đã soát trong tháng"
                            android:textSize="12sp"
                            android:textColor="#6B7E94"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════ -->
            <!-- UPCOMING SHOWTIMES SECTION                 -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="#3B82F6"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SẮP CHIẾU"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textColor="#3B82F6" />

                <TextView
                    android:id="@+id/tvUpcomingSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="(trong 60 phút tới)"
                    android:textSize="11sp"
                    android:textColor="#4A5568" />
            </LinearLayout>

            <!-- Empty state cho upcoming -->
            <TextView
                android:id="@+id/tvUpcomingEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Không có suất chiếu nào sắp bắt đầu"
                android:textSize="13sp"
                android:textColor="#4A5568"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:paddingHorizontal="20dp"
                android:visibility="gone" />

            <!-- RecyclerView suất chiếu sắp tới -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvUpcomingShowtimes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
