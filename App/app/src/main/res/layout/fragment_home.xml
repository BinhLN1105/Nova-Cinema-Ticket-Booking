<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Thanh tiêu đề cố định hoặc tự động ẩn (Sticky Header) -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:layout_scrollFlags="scroll|enterAlways"
            android:paddingHorizontal="16dp"
            android:background="@color/surface_container">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSearch"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="@color/on_surface_variant"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="0dp"
                        android:hint="Tìm phim..."
                        android:textSize="12sp"
                        android:background="@drawable/bg_search_box"
                        android:imeOptions="actionSearch"
                        android:inputType="text"/>
                </com.google.android.material.textfield.TextInputLayout>

                <ImageView
                    android:id="@+id/btnLocation"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/tvCurrentLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HCM"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/btnNotification"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/on_surface"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivUserAvatar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/on_surface_variant"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
                    android:scaleType="centerCrop" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="96dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Phần phim nổi bật (Hero Section) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:background="@color/surface_container_lowest">
                    
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpHero"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                        
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_gradient_bottom" />

                    <TextView
                        android:id="@+id/tvHeroTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginHorizontal="32dp"
                        android:layout_marginBottom="12dp"
                        app:layout_constraintBottom_toTopOf="@id/btnBookHero"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookHero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MUA VÉ NGAY"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="24dp"
                        android:layout_marginBottom="32dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Thẻ đặt vé nhanh (Quick Booking Card) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="-32dp"
                    app:cardBackgroundColor="@color/surface_container_highest"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        
                        <LinearLayout
                            android:id="@+id/btnQuickMovie"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_movie" app:tint="@color/primary"/>
                            <TextView android:id="@+id/tvQuickMovie" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phim" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/outline_variant"/>

                        <LinearLayout
                            android:id="@+id/btnQuickCinema"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_location" app:tint="@color/primary"/>
                            <TextView android:id="@+id/tvQuickCinema" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rạp" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="@color/outline_variant"/>

                        <LinearLayout
                            android:id="@+id/btnQuickDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" android:rotation="90" app:tint="@color/primary"/>
                            <TextView android:id="@+id/tvQuickDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày" android:textSize="10sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnQuickSubmit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MUA"
                            app:cornerRadius="12dp"
                            android:layout_marginStart="8dp"
                            app:paddingStart="12dp"
                            app:paddingEnd="12dp"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tab chọn danh sách: Đang chiếu | Sắp chiếu -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayoutMovies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@android:color/transparent"
                    app:tabIndicatorColor="@color/primary"
                    app:tabSelectedTextColor="@color/primary"
                    app:tabTextColor="@color/on_surface_variant"
                    app:tabIndicatorHeight="3dp"
                    app:tabIndicatorFullWidth="false"
                    app:tabTextAppearance="@style/TextApp.TabLabel">
                    <com.google.android.material.tabs.TabItem android:text="ĐANG CHIẾU" />
                    <com.google.android.material.tabs.TabItem android:text="SẮP CHIẾU" />
                </com.google.android.material.tabs.TabLayout>

                <!-- Lưới hiển thị danh sách phim -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMovies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:listitem="@layout/item_movie" />

                <!-- Khu vực Khuyến mãi & Vouchers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="32dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="KHUYẾN MÃI HOT"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSeeAllPromotions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem tất cả"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:padding="4dp" />
                </LinearLayout>                
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvPromoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginHorizontal="24dp"
                    app:cardCornerRadius="20dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface_container_lowest">
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vpPromotions"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayoutPromo"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    app:tabBackground="@drawable/tab_indicator" 
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabRippleColor="@null"
                    app:tabPaddingStart="2dp"
                    app:tabPaddingEnd="2dp"
                    app:tabMinWidth="6dp"
                    app:tabMaxWidth="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone" android:indeterminateTint="@color/primary"
        android:layout_gravity="center"/>

    <!-- Kết quả tìm kiếm (Search Results) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="@color/background"
        android:visibility="gone"
        android:elevation="11dp"
        android:padding="12dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- Lớp phủ mờ khi đang tìm kiếm (Search Dim Background) -->
    <View
        android:id="@+id/viewSearchDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:elevation="10dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
