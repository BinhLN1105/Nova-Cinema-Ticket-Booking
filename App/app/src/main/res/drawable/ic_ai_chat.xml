<?xml version="1.0" encoding="utf-8"?>
<!--
    Icon AI Chatbot - Robot chat bubble
    Grad: orange #FF7040 -> coral #FF4465 -> pink #FF2878
    minSdk 24+ supports <aapt:attr> gradient in VectorDrawable
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="56dp"
    android:height="56dp"
    android:viewportWidth="56"
    android:viewportHeight="56">

    <!-- ── Tai trái ────────────────────────────────────────────────────── -->
    <path android:pathData="M6,18 L10,18 Q11,18 11,19 L11,26 Q11,27 10,27 L6,27 Q4,27 4,25 L4,20 Q4,18 6,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="4" android:startY="18"
                android:endX="11" android:endY="27">
                <item android:offset="0" android:color="#FFFF7040"/>
                <item android:offset="1" android:color="#FFFF4465"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Tai phải ───────────────────────────────────────────────────── -->
    <path android:pathData="M50,18 L46,18 Q45,18 45,19 L45,26 Q45,27 46,27 L50,27 Q52,27 52,25 L52,20 Q52,18 50,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="45" android:startY="18"
                android:endX="52" android:endY="27">
                <item android:offset="0" android:color="#FFFF6038"/>
                <item android:offset="1" android:color="#FFFF3060"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Thân bubble chính (rounded rect + mũi tên dưới) ──────────── -->
    <!--
        Hình: left=11, top=7, right=45, bottom=38
        Bo góc ~6. Mũi tên: (24,38)->(28,44)->(32,38)
    -->
    <path android:pathData="
        M17,7
        Q11,7 11,13
        L11,38
        L24,38
        L28,44
        L32,38
        L39,38
        Q45,38 45,32
        L45,13
        Q45,7 39,7
        Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="11" android:startY="7"
                android:endX="45" android:endY="44">
                <item android:offset="0"   android:color="#FFFF7040"/>
                <item android:offset="0.5" android:color="#FFFF4465"/>
                <item android:offset="1"   android:color="#FFFF1878"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Mắt trái (dark oval dọc) ─────────────────────────────────── -->
    <path
        android:fillColor="#22000000"
        android:pathData="M21,13 Q21,10 24,10 Q27,10 27,13 L27,22 Q27,25 24,25 Q21,25 21,22 Z"/>

    <!-- ── Mắt phải (dark oval dọc) ──────────────────────────────────── -->
    <path
        android:fillColor="#22000000"
        android:pathData="M29,13 Q29,10 32,10 Q35,10 35,13 L35,22 Q35,25 32,25 Q29,25 29,22 Z"/>

</vector>
