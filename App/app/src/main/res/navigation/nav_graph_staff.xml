<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_staff"
    app:startDestination="@id/staffHomeFragment">

    <action android:id="@+id/action_global_promotionList" app:destination="@id/promotionListFragment"/>

    <fragment android:id="@+id/promotionListFragment"
        android:name="com.cinema.ticket_booking.ui.promotion.PromotionListFragment"
        android:label="Khuyến Mãi" />

    <fragment android:id="@+id/staffHomeFragment"
        android:name="com.cinema.ticket_booking.ui.home.StaffHomeFragment"
        android:label="Dashboard">
        <action android:id="@+id/action_staffHome_to_cinemaDetail"
            app:destination="@id/cinemaDetailFragment" />
        <action android:id="@+id/action_staffHome_to_checkInHistory"
            app:destination="@id/checkInHistoryFragment" />
    </fragment>

    <fragment android:id="@+id/searchFragment"
        android:name="com.cinema.ticket_booking.ui.search.SearchFragment"
        android:label="Lịch chiếu" />

    <!-- Cinema Detail — xem lịch chiếu theo rạp -->
    <fragment android:id="@+id/cinemaDetailFragment"
        android:name="com.cinema.ticket_booking.ui.search.CinemaDetailFragment"
        android:label="Chi tiết rạp">
        <argument android:name="cinemaId" app:argType="string"/>
        <argument android:name="cinemaName" app:argType="string"/>
        <!-- Staff chỉ xem lịch, không đặt vé → navigate đến seat để xem, không booking -->
        <action android:id="@+id/action_selectShowtime_to_selectSeat"
            app:destination="@id/selectSeatFragment"
            app:popUpTo="@id/searchFragment" />
    </fragment>

    <!-- Select Seat (readonly view cho staff — chỉ xem sơ đồ ghế) -->
    <fragment android:id="@+id/selectSeatFragment"
        android:name="com.cinema.ticket_booking.ui.booking.SelectSeatFragment"
        android:label="Sơ đồ ghế">
        <argument android:name="showtimeId" app:argType="string"/>
    </fragment>

    <fragment android:id="@+id/scannerFragment"
        android:name="com.cinema.ticket_booking.ui.scanner.ScannerFragment"
        android:label="Soát vé" />

    <fragment android:id="@+id/checkInHistoryFragment"
        android:name="com.cinema.ticket_booking.ui.staff.CheckInHistoryFragment"
        android:label="Lịch sử soát vé" />

    <fragment android:id="@+id/profileFragment"
        android:name="com.cinema.ticket_booking.ui.profile.ProfileFragment"
        android:label="Tài khoản">
        <action android:id="@+id/action_profile_to_login" app:destination="@id/loginFragment"
            app:popUpTo="@id/staffHomeFragment" app:popUpToInclusive="true"/>
    </fragment>

    <fragment android:id="@+id/loginFragment"
        android:name="com.cinema.ticket_booking.ui.auth.LoginFragment"
        android:label="Đăng nhập" />

    <dialog android:id="@+id/chatbotBottomSheet"
        android:name="com.cinema.ticket_booking.ui.chatbot.ChatbotBottomSheet"
        android:label="Nova Assistant" />

    <fragment android:id="@+id/movieDetailFragment"
        android:name="com.cinema.ticket_booking.ui.movie.MovieDetailFragment"
        android:label="Chi tiết phim">
        <argument android:name="movieId" app:argType="string"/>
        <action android:id="@+id/action_movieDetail_to_reviewList" app:destination="@id/reviewListFragment"/>
    </fragment>

    <fragment android:id="@+id/reviewListFragment"
        android:name="com.cinema.ticket_booking.ui.movie.ReviewListFragment"
        android:label="Đánh giá phim">
        <argument android:name="movieId" app:argType="string"/>
    </fragment>

</navigation>
