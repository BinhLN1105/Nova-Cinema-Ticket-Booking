    {
      "name": "11. GET Fetch Showtime Seats",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.test(\"Get seat map success\", function () {",
              "    pm.expect(pm.response.code).to.equal(200);",
              "    pm.expect(jsonData.data.seats.length).to.be.above(0);",
              "});",
              "var seats = jsonData.data.seats;",
              "var available = seats.filter(function(s) { return s.status === 'AVAILABLE'; });",
              "if (available.length >= 2) {",
              "  pm.environment.set(\"selected_seat_1\", available[0].showtimeSeatId);",
              "  pm.environment.set(\"selected_seat_2\", available[1].showtimeSeatId);",
              "} else if (available.length >= 1) {",
              "  pm.environment.set(\"selected_seat_1\", available[0].showtimeSeatId);",
              "  pm.environment.set(\"selected_seat_2\", available[0].showtimeSeatId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
