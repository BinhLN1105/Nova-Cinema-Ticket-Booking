    {
      "name": "4. POST Create Movie",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const today = new Date();",
              "const start = today.toISOString().split('T')[0];",
              "const nextMonth = new Date();",
              "nextMonth.setMonth(nextMonth.getMonth() + 1);",
              "const end = nextMonth.toISOString().split('T')[0];",
              "pm.environment.set(\"movie_release_date\", start);",
              "pm.environment.set(\"movie_end_date\", end);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.test(\"Create movie success\", function () {",
              "    pm.expect(pm.response.code).to.equal(201);",
              "    pm.expect(jsonData.data.id).to.exist;",
              "});",
              "pm.environment.set(\"movie_id\", jsonData.data.id);",
              "pm.environment.set(\"movie_name\", jsonData.data.title);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
