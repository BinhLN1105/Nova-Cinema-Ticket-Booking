            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Phim Siêu Nhân E2E\",\n  \"originalTitle\": \"Superman E2E\",\n  \"description\": \"Phim test giao diện tự động\",\n  \"duration\": 120,\n  \"releaseDate\": \"{{movie_release_date}}\",\n  \"endDate\": \"{{movie_end_date}}\",\n  \"director\": \"Nova Director\",\n  \"cast\": \"Nova Cast\",\n  \"language\": \"Vietnamese\",\n  \"rated\": \"P\",\n  \"status\": \"NOW_SHOWING\",\n  \"genreIds\": []\n}"
