				{
					"name": "1.1 Customer Auth Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{registered_email}}\",\n    \"password\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{BaseUrl}}/api/v1/auth/login",
							"host": [
								"{{BaseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (!pm.environment.get(\"registered_email\")) {",
									"    pm.environment.set(\"registered_email\", \"customer_test@novaticket.com\");",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Login customer thành công\", function () {",
									"    pm.response.to.have.status(200);",
									"    const response = pm.response.json();",
									"    pm.environment.set(\"customer_accessToken\", response.data.accessToken);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
