							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Số dư ví CinePoint giảm sau thanh toán\", function () {",
									"    pm.response.to.have.status(200);",
									"    const response = pm.response.json();",
									"    const prevPoints = parseInt(pm.environment.get(\"prev_reward_points\"));",
									"    const currentPoints = response.data.rewardPoints;",
									"    pm.expect(currentPoints).to.be.below(prevPoints);",
									"    pm.environment.set(\"paid_reward_points_1\", currentPoints);",
									"});",
									"pm.test(\"Điểm EXP tăng sau thanh toán\", function () {",
									"    const response = pm.response.json();",
									"    const prevExp = parseInt(pm.environment.get(\"prev_available_exp\"));",
									"    const currentExp = response.data.availableExp;",
									"    pm.expect(currentExp).to.be.above(prevExp);",
									"    pm.environment.set(\"paid_available_exp_1\", currentExp);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
