    {
      "name": "GET Seat Layout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response success is true\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.success).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"Data has exactly 4 seats\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.data).to.be.an(\"array\");\r",
              "    pm.expect(json.data.length).to.eql(4);\r",
              "});\r",
              "\r",
              "pm.test(\"Seat layout contains A1, A2, B1, B2\", function () {\r",
              "    const json = pm.response.json();\r",
              "    const labels = json.data.map(seat => seat.seatLabel);\r",
              "\r",
              "    pm.expect(labels).to.include(\"A1\");\r",
              "    pm.expect(labels).to.include(\"A2\");\r",
              "    pm.expect(labels).to.include(\"B1\");\r",
              "    pm.expect(labels).to.include(\"B2\");\r",
              "});\r",
              "\r",
              "pm.test(\"Seat coordinates are correct\", function () {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    const a1 = json.data.find(seat => seat.seatLabel === \"A1\");\r",
              "    const a2 = json.data.find(seat => seat.seatLabel === \"A2\");\r",
              "    const b1 = json.data.find(seat => seat.seatLabel === \"B1\");\r",
              "    const b2 = json.data.find(seat => seat.seatLabel === \"B2\");\r",
              "\r",
              "    pm.expect(a1.gridRow).to.eql(0);\r",
              "    pm.expect(a1.gridCol).to.eql(0);\r",
              "\r",
              "    pm.expect(a2.gridRow).to.eql(0);\r",
              "    pm.expect(a2.gridCol).to.eql(1);\r",
              "\r",
              "    pm.expect(b1.gridRow).to.eql(1);\r",
              "    pm.expect(b1.gridCol).to.eql(0);\r",
              "\r",
              "    pm.expect(b2.gridRow).to.eql(1);\r",
              "    pm.expect(b2.gridCol).to.eql(1);\r",
              "});\r",
              "\r",
              "pm.test(\"Seat types are correct\", function () {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    const a1 = json.data.find(seat => seat.seatLabel === \"A1\");\r",
              "    const a2 = json.data.find(seat => seat.seatLabel === \"A2\");\r",
              "    const b1 = json.data.find(seat => seat.seatLabel === \"B1\");\r",
              "    const b2 = json.data.find(seat => seat.seatLabel === \"B2\");\r",
              "\r",
              "    pm.expect(a1.seatType).to.eql(\"STANDARD\");\r",
              "    pm.expect(a2.seatType).to.eql(\"STANDARD\");\r",
              "    pm.expect(b1.seatType).to.eql(\"VIP\");\r",
              "    pm.expect(b2.seatType).to.eql(\"VIP\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
