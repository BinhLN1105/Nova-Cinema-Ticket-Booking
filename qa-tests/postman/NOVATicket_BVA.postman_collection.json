    {
      "name": "2. BVA - Movie Rating (Scale 1-5)",
      "item": [
        {
          "name": "BVA_RAT_01: Biên dưới rating không hợp lệ [Rating = 0]",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Rating = 0 bị chặn - Trả về 400 Bad Request\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "    var responseData = pm.response.json();\r",
                  "    pm.expect(responseData.message).to.contain(\"Rating tối thiểu là 1\");\r",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"movieId\": \"{{test_movie_id}}\",\r\n  \"bookingId\": \"{{booking_id}}\",\r\n  \"rating\": 0,\r\n  \"comment\": \"Phim rất hay!\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseUrl}}/api/v1/reviews",
              "host": [
                "{{BaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reviews"
              ]
            }
          },
          "response": []
        },
        {
          "name": "BVA_RAT_02: Biên dưới rating hợp lệ nhỏ nhất [Rating = 1]",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Nếu test_movie_id chưa được gán, dùng UUID ngẫu nhiên làm giá trị mặc định để tránh lỗi rỗng\r",
                  "if (!pm.environment.get(\"test_movie_id\")) {\r",
                  "    pm.environment.set(\"test_movie_id\", \"00000000-0000-0000-0000-000000000000\");\r",
                  "}\r",
                  "if (!pm.environment.get(\"booking_id\")) {\r",
                  "    pm.environment.set(\"booking_id\", \"00000000-0000-0000-0000-000000000000\");\r",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Rating = 1 được chấp nhận qua lớp Validate\", function () {\r",
                  "    var responseData = pm.response.json();\r",
                  "    // Đi qua được validator nên không báo lỗi Rating tối thiểu là 1\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 401, 404]);\r",
                  "    if (pm.response.code === 400) {\r",
                  "        pm.expect(responseData.message).to.not.include(\"Rating tối thiểu là 1\");\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"movieId\": \"{{test_movie_id}}\",\r\n  \"bookingId\": \"{{booking_id}}\",\r\n  \"rating\": 1,\r\n  \"comment\": \"Tạm được!\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseUrl}}/api/v1/reviews",
              "host": [
                "{{BaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reviews"
              ]
            }
          },
          "response": []
        },
        {
          "name": "BVA_RAT_03: Biên trên rating hợp lệ lớn nhất [Rating = 5]",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Rating = 5 được chấp nhận qua lớp Validate\", function () {\r",
